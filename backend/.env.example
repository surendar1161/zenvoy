# These are set via `supabase secrets set` (not committed to git)
# Run: supabase secrets set KEY=value

# Supabase (auto-injected in Edge Functions — no need to set manually)
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Chargebee
CHARGEBEE_SITE=your-site-name
CHARGEBEE_API_KEY=your_full_access_key
CHARGEBEE_PRO_MONTHLY_PLAN_ID=pro-monthly
CHARGEBEE_PRO_YEARLY_PLAN_ID=pro-yearly
CHARGEBEE_BUSINESS_MONTHLY_PLAN_ID=business-monthly
CHARGEBEE_BUSINESS_YEARLY_PLAN_ID=business-yearly
CHARGEBEE_WEBHOOK_PASSWORD=optional_password

# Frontend URL (for payment link redirects)
FRONTEND_URL=https://your-app.vercel.app
