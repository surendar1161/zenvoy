# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# ── Chargebee ─────────────────────────────────────────────────────
CHARGEBEE_SITE=your-site-name
CHARGEBEE_API_KEY=your-full-access-key
CHARGEBEE_PRO_MONTHLY_PLAN_ID=pro-monthly
CHARGEBEE_PRO_YEARLY_PLAN_ID=pro-yearly
CHARGEBEE_BUSINESS_MONTHLY_PLAN_ID=business-monthly
CHARGEBEE_BUSINESS_YEARLY_PLAN_ID=business-yearly
CHARGEBEE_WEBHOOK_PASSWORD=your-webhook-password

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
GOOGLE_SITE_VERIFICATION=your-verification-token
